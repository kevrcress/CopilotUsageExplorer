{
  "name": "copilot-usage-explorer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Local viewer for GitHub Copilot Chat agent debug logs (token usage + optimization insights).",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "build": "npm run build -w apps/web",
    "preview": "npm run preview -w apps/web",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync-version": "node scripts/sync-version.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}

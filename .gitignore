# Real personal Copilot debug logs used for local dev/testing — never commit.
# They contain source code and conversation content.
# NOTE: macOS is case-insensitive, so Examples/ and examples/ are the SAME
# directory. There is no separate tracked sample-data folder — tests use
# fixtures in packages/core/test/fixtures/. Do not "fix" this by force-adding
# Examples/; that would publish real logs.
examples/

# Not source — a redundant project snapshot and personal training material.
UpdatedCopilotUsageExplorer.zip
Copilot 101 And Optimization.pdf

# Extension packaging artifacts
*.vsix

# Electron build output
apps/electron/out/
apps/electron/release/

# HVE tracking: durable artifacts (research/plans/details/changes/reviews/etc.)
# are committed; only regenerable per-subagent raw output and scratch runs are not.
.claude-hve-tracking/**/subagents/
.claude-hve-tracking/sandbox/
